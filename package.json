{
  "name": "@policies2/sdk",
  "version": "0.1.0",
  "description": "TypeScript SDK for executing policies and flows over REST or gRPC.",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "generate:rpc-schema": "node scripts/generate-rpc-schema.mjs",
    "build": "tsc",
    "build:examples": "tsc --module NodeNext --moduleResolution NodeNext --target ES2022 --outDir dist/examples examples/*.ts",
    "typecheck": "tsc --noEmit",
    "test": "bun test",
    "prepublishOnly": "bun run generate:rpc-schema && tsc"
  },
  "keywords": [
    "policy",
    "sdk",
    "typescript",
    "grpc",
    "rest"
  ],
  "license": "MIT",
  "dependencies": {
    "@grpc/grpc-js": "^1.14.0",
    "protobufjs": "^8.0.0"
  },
  "devDependencies": {
    "@types/bun": "^1.3.9",
    "protobufjs-cli": "^1.1.3",
    "typescript": "^5.9.3"
  }
}
